{
  "extends":"./node_modules/expo/tsconfig.base",
  
    "compilerOptions": {
      "moduleResolution": "node",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "baseUrl": "./",
      "paths": {
        "*": [
          "node_modules/*"
        ]
      }
    },
  

  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}